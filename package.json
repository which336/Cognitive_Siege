{
  "name": "cognitive-siege",
  "version": "0.1.0",
  "type": "module",
  "description": "Cognitive Siege - LLM-driven adaptive tower defense set inside a patient's subconscious.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc --noEmit",
    "audio:generate": "node ./scripts/generate-audio.mjs",
    "deploy:pages": "npm run build && node ./scripts/deploy-pages.mjs"
  },
  "dependencies": {
    "phaser": "^3.80.1"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  }
}
